# XenosFinance — Cloudflare Pages Redirects
# Fixes 404s from old WordPress URLs indexed by Google

# Old WordPress blog/post URLs → AI Blog
/blog                           https://xenosfinance.com/XenosBlog    301
/blog/                          https://xenosfinance.com/XenosBlog    301
/blog/*                         https://xenosfinance.com/XenosBlog    301
/market-news                    https://xenosfinance.com               301
/market-news/                   https://xenosfinance.com               301
/market-news/*                  https://xenosfinance.com               301

# WordPress query string URLs → homepage
/?p=*                           https://xenosfinance.com               301
/?cat=*                         https://xenosfinance.com               301
/?page_id=*                     https://xenosfinance.com               301
/?s=*                           https://xenosfinance.com               301
/?tag=*                         https://xenosfinance.com               301
/?author=*                      https://xenosfinance.com               301

# WordPress admin/system paths
/wp-admin/*                     https://xenosfinance.com               301
/wp-content/*                   https://xenosfinance.com               301
/wp-includes/*                  https://xenosfinance.com               301
/wp-login.php                   https://xenosfinance.com               301
/feed                           https://xenosfinance.com               301
/feed/                          https://xenosfinance.com               301
/xmlrpc.php                     https://xenosfinance.com               301

# www → non-www (fallback for any www requests)
https://www.xenosfinance.com/*  https://xenosfinance.com/:splat        301
